ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "METRICS_ANOMALY_SCORE", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "MODEL_RUN_RESULTS", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "MONITORS_RUNS", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "SCHEMA_COLUMNS_SNAPSHOT", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "SEED_RUN_RESULTS", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "SNAPSHOT_RUN_RESULTS", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "TEST_RESULT_ROWS", "schema": "ELEMENTARY"}], "schema": "elementary"}, "info": {"category": "", "code": "E014", "extra": {}, "invocation_id": "7ba3ae76-c37d-43fd-a4f0-2bd9b4df16de", "level": "debug", "msg": "While listing relations in database=jnadal_db, schema=elementary, found: ALERTS_ANOMALY_DETECTION, ALERTS_DBT_MODELS, ALERTS_DBT_SOURCE_FRESHNESS, ALERTS_DBT_TESTS, ALERTS_SCHEMA_CHANGES, ANOMALY_THRESHOLD_SENSITIVITY, DATA_MONITORING_METRICS, DBT_ARTIFACTS_HASHES, DBT_COLUMNS, DBT_EXPOSURES, DBT_GROUPS, DBT_INVOCATIONS, DBT_METRICS, DBT_MODELS, DBT_RUN_RESULTS, DBT_SEEDS, DBT_SNAPSHOTS, DBT_SOURCES, DBT_SOURCE_FRESHNESS_RESULTS, DBT_TESTS, ELEMENTARY_TEST_RESULTS, JOB_RUN_RESULTS, METADATA, METRICS_ANOMALY_SCORE, MODEL_RUN_RESULTS, MONITORS_RUNS, SCHEMA_COLUMNS_SNAPSHOT, SEED_RUN_RESULTS, SNAPSHOT_RUN_RESULTS, TEST_RESULT_ROWS", "name": "ListRelations", "pid": 2578, "thread": "MainThread", "ts": "2026-03-21T01:06:30.420698Z"}}
