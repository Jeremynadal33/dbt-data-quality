{"data": {"conn_name": "macro_log_macro_results", "sql": "with dbt_artifacts_snapshots as (\n                select \n                  name,\n                  case when alias is not null then alias\n                  else name end as table_name,\n                  unique_id,\n                  owner as owners,\n                  tags,\n                  package_name,\n                  description,\n                  meta,\n                  materialization,\n                  database_name,\n                  schema_name,\n                  depends_on_macros,\n                  depends_on_nodes,\n                  original_path as full_path,\n                  path,\n                  patch_path,\n                  generated_at,\n                  unique_key,\n                  incremental_strategy\n                from jnadal_db.elementary.dbt_snapshots\n              )\n            select * from dbt_artifacts_snapshots\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"0523b505-0328-420e-8799-469078f5f70a\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.6\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "0523b505-0328-420e-8799-469078f5f70a", "level": "debug", "msg": "On macro_log_macro_results: with dbt_artifacts_snapshots as (\n                select \n                  name,\n                  case when alias is not null then alias\n                  else name end as table_name,\n                  unique_id,\n                  owner as owners,\n                  tags,\n                  package_name,\n                  description,\n                  meta,\n                  materialization,\n                  database