{"data": {"conn_name": "macro_log_macro_results", "sql": "with dbt_tests as (\n                select\n                    parent_model_unique_id,\n                    test_column_name\n                from jnadal_db.elementary.dbt_tests\n            )\n\n            select \n                parent_model_unique_id as model_unique_id,\n                SUM(\n                    case \n                        when test_column_name is not null then 1\n                        else 0\n                        end\n                ) as column_tests,\n                 SUM(\n                    case\n                        when test_column_name is null then 1\n                        else 0\n                        end \n                )as table_tests\n            from dbt_tests\n            group by parent_model_unique_id\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"b992ab28-82fe-4b42-bca7-93695294b0fc\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "b992ab28-82fe-4b42-bca7-93695294b0fc", "level": "debug", "msg": "On macro_log_macro_results: with dbt_tests as (\n                select\n                    parent_model_unique_id,\n                    test_column_name\n                from jnadal_db.elementary.dbt_tests\n            )\n\n            select \n                parent_model_unique_id as model_unique_id,\n                SUM(\n                    case \n                        when test_column_name is not null then 1\n                        else 0\n                        end\n                ) as column_tests,\n                 SUM(\n                    case\n                        when test_column_name is null then 1\n                        else 0\n                        end \n                )as table_tests\n            from dbt_tests\n            group by parent_model_unique_id\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"b992ab28-82fe-4b42-bca7-93695294b0fc\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */", "name": "SQLQuery", "pid": 2569, "thread": "MainThread", "ts": "2026-05-05T01:52:23.563676Z"}}
