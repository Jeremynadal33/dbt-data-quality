{"data": {"conn_name": "macro_log_macro_results", "sql": "with model_runs as (\n            select\n                *,\n                row_number() over (partition by unique_id order by generated_at desc) as invocations_rank_index\n            from jnadal_db.elementary.model_run_results\n        )\n\n        select\n            unique_id,\n            invocation_id,\n            name,\n            schema_name as schema,\n            status,\n            case\n                when status != 'success' then 0\n                else round(cast(execution_time as numeric(28,6)), 1)\n            end as execution_time,\n            full_refresh,\n            materialization,\n            case when invocations_rank_index = 1 then compiled_code else NULL end as compiled_code,\n            generated_at\n        from model_runs\n        where datediff(\n        day,\n        cast(generated_at as timestamp),\n        \n  current_timestamp::timestamp\n\n        ) < 7\n        \n          and unique_id not like 'model.elementary.%'\n        \n        order by generated_at\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"0567f0b8-1f8d-4e72-81f8-83b215550df3\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.6\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "0567f0b8-1f8d-4e72-81f8-83b215550df3", "level": "debug", "msg": "On macro_log_macro_results: with model_runs as (\n            select\n                *,\n                row_number() over (partition by unique_id order by generated_at desc) as invocations_rank_index\n            from jnadal_db.elementary.model_run_results\n        )\n\n        select\n            unique_id,\n            invocation_id,\n            name,\n            schema_name as schema,\n            status,\n            case\n                when status != 'success' then 0\n                else round(cast(execution_time as numeric(28,6)), 1)\n            end as execution_time,\n            full_refresh,\n            materialization,\n            case when invocations_rank_index = 1 then compiled_code else NULL end as compiled_code,\n            generated_at\n        from model_runs\n        where datediff(\n        day,\n        cast(generated_at as timestamp),\n        \n  current_timestamp::timestamp\n\n        ) < 7\n        \n          and unique_id not like 'model.elementary.%'\n        \n        order by generated_at\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"0567f0b8-1f8d-4e72-81f8-83b215550df3\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.6\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */", "name": "SQLQuery", "pid": 2556, "thread": "MainThread", "ts": "2026-04-09T01:12:34.693761Z"}}
