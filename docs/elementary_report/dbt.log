ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "METRICS_ANOMALY_SCORE", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "MODEL_RUN_RESULTS", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "MONITORS_RUNS", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "SCHEMA_COLUMNS_SNAPSHOT", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "SEED_RUN_RESULTS", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "SNAPSHOT_RUN_RESULTS", "schema": "ELEMENTARY"}, {"database": "JNADAL_DB", "identifier": "TEST_RESULT_ROWS", "schema": "ELEMENTARY"}], "schema": "elementary"}, "info": {"category": "", "code": "E014", "extra": {}, "invocation_id": "5d0ae315-e9d0-4e86-a0b7-45076df89931", "level": "debug", "msg": "While listing relations in database=jnadal_db, schema=elementary, found: ALERTS_ANOMALY_DETECTION, ALERTS_DBT_MODELS, ALERTS_DBT_SOURCE_FRESHNESS, ALERTS_DBT_TESTS, ALERTS_SCHEMA_CHANGES, ANOMALY_THRESHOLD_SENSITIVITY, DATA_MONITORING_METRICS, DBT_ARTIFACTS_HASHES, DBT_COLUMNS, DBT_EXPOSURES, DBT_GROUPS, DBT_INVOCATIONS, DBT_METRICS, DBT_MODELS, DBT_RUN_RESULTS, DBT_SEEDS, DBT_SNAPSHOTS, DBT_SOURCES, DBT_SOURCE_FRESHNESS_RESULTS, DBT_TESTS, ELEMENTARY_TEST_RESULTS, JOB_RUN_RESULTS, METADATA, METRICS_ANOMALY_SCORE, MODEL_RUN_RESULTS, MONITORS_RUNS, SCHEMA_COLUMNS_SNAPSHOT, SEED_RUN_RESULTS, SNAPSHOT_RUN_RESULTS, TEST_RESULT_ROWS", "name": "ListRelations", "pid": 2557, "thread": "MainThread", "ts": "2026-03-31T01:20:17.735416Z"}}
