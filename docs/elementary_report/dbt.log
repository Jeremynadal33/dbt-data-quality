           patch_path,\n                  \n                  original_path as full_path,\n                  meta\n                from jnadal_db.elementary.dbt_models\n                \n                  where package_name != 'elementary'\n                \n              )\n\n             select * from dbt_artifacts_models\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"5fa00183-0d3c-442d-9ee7-f4d2332668be\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.6\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */", "name": "SQLQuery", "pid": 2572, "thread": "MainThread", "ts": "2026-04-19T01:30:13.194355Z"}}
