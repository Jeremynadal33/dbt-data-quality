{"data": {"conn_name": "macro_log_macro_results", "sql": "with ordered_run_results as (\n      select\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from jnadal_db.elementary.dbt_run_results run_results\n      join jnadal_db.elementary.dbt_models models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_models_invocations as (\n      select distinct invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select\n      invocations.invocation_id,\n      invocations.command,\n      invocations.selected,\n      invocations.full_refresh,\n      \n        invocations.job_url,\n      \n      invocations.job_name,\n      invocations.job_id,\n      invocations.orchestrator\n    from jnadal_db.elementary.dbt_invocations invocations\n    join latest_models_invocations on invocations.invocation_id = latest_models_invocations.invocation_id\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"71b7d4d2-0f5b-4a62-b2c1-9875bee802c6\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "71b7d4d2-0f5b-4a62-b2c1-9875bee802c6", "level": "debug", "msg": "On macro_log_macro_results: with ordered_run_results as (\n      select\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from jnadal_db.elementary.dbt_run_results run_results\n      join jnadal_db.elementary.dbt_models models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_models_invocations as (\n      select distinct invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select\n      invocations.invocation_id,\n      invocations.command,\n      invocations.selected,\n      invocations.full_refresh,\n      \n        invocations.job_url,\n      \n      invocations.job_name,\n      invocations.job_id,\n      invocations.orchestrator\n    from jnadal_db.elementary.dbt_invocations invocations\n    join latest_models_invocations on invocations.invocation_id = latest_models_invocations.invocation_id\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"71b7d4d2-0f5b-4a62-b2c1-9875bee802c6\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */", "name": "SQLQuery", "pid": 2547, "thread": "MainThread", "ts": "2026-04-21T01:27:00.736554Z"}}
