{"data": {"conn_name": "macro_log_macro_results", "sql": "select\n            unique_id,\n            null as depends_on_nodes,\n            null as materialization,\n            'seed' as type\n        from jnadal_db.elementary.dbt_seeds\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            materialization,\n            'snapshot' as type\n        from jnadal_db.elementary.dbt_snapshots\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            materialization,\n            'model' as type\n        from jnadal_db.elementary.dbt_models\n        \n            where package_name != 'elementary'\n        \n        union all\n        select\n            unique_id,\n            null as depends_on_nodes,\n            null as materialization,\n            'source' as type\n        from jnadal_db.elementary.dbt_sources\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            null as materialization,\n            'exposure' as type\n        from jnadal_db.elementary.dbt_exposures\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"332447a0-c16e-48ab-97ab-210b675050b5\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "332447a0-c16e-48ab-97ab-210b675050b5", "level": "debug", "msg": "On macro_log_macro_results: select\n            unique_id,\n            null as depends_on_nodes,\n            null as materialization,\n            'seed' as type\n        from jnadal_db.elementary.dbt_seeds\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            materialization,\n            'snapshot' as type\n        from jnadal_db.elementary.dbt_snapshots\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            materialization,\n            'model' as type\n        from jnadal_db.elementary.dbt_models\n        \n            where package_name != 'elementary'\n        \n        union all\n        select\n            unique_id,\n            null as depends_on_nodes,\n            null as materialization,\n            'source' as type\n        from jnadal_db.elementary.dbt_sources\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            null as materialization,\n            'exposure' as type\n        from jnadal_db.elementary.dbt_exposures\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"332447a0-c16e-48ab-97ab-210b675050b5\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */", "name": "SQLQuery", "pid": 2582, "thread": "MainThread", "ts": "2026-05-02T01:47:58.456115Z"}}
