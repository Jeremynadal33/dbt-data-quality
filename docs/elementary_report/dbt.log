{"data": {"conn_name": "macro_log_macro_results", "sql": "with ordered_run_results as (\n      select\n        run_results.unique_id,\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from jnadal_db.elementary.dbt_run_results run_results\n      join jnadal_db.elementary.dbt_models models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_run_results as (\n      select unique_id, invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select unique_id, invocation_id from latest_run_results\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"2bccbe25-6c42-4b8d-94f5-25dcf963997d\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.6\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "2bccbe25-6c42-4b8d-94f5-25dcf963997d", "level": "debug", "msg": "On macro_log_macro_results: with ordered_run_results as (\n      select\n        run_results.unique_id,\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from jnadal_db.elementary.dbt_run_results run_results\n      join jnadal_db.elementary.dbt_models models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_run_results as (\n      select unique_id, invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select unique_id, invocation_id from latest_run_results\n/* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"2bccbe25-6c42-4b8d-94f5-25dcf963997d\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.6\", \"profile_name\": \"elementary\", \"target_name\": \"prod\", \"connection_name\": \"macro_log_macro_results\"} */", "name": "SQLQuery", "pid": 2553, "thread": "MainThread", "ts": "2026-03-20T01:11:32.901973Z"}}
